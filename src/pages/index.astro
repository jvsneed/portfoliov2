<script>
    import Swiper from 'swiper';
    import { Navigation } from 'swiper/modules';

    // Scroll progress indicator
    window.addEventListener('scroll', () => {
        const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        const progressBar = document.querySelector('.scroll-progress') as HTMLElement;
        progressBar?.style.setProperty('--scroll', `${scrollPercent}%`);
    });

    function initProjectNavigation() {
        const swiper = new Swiper('.projects-container', {
            modules: [Navigation],
            slidesPerView: 2, // Show 2 slides at once on desktop
            spaceBetween: 16,
            grabCursor: true,
            centeredSlides: false,
            initialSlide: 0,
            navigation: {
                prevEl: '.custom-prev',
                nextEl: '.custom-next',
            },
            breakpoints: {
                // Desktop view
                768: {
                    enabled: true,
                    slidesPerView: 2,
                    spaceBetween: 16,
                },
                // Mobile view
                0: {
                    enabled: true,
                    slidesPerView: 1,
                    spaceBetween: 16,
                }
            },
            on: {
                slideChange: function() {
                    const prevBtn = document.querySelector('.custom-prev') as HTMLButtonElement;
                    const nextBtn = document.querySelector('.custom-next') as HTMLButtonElement;
                    if (prevBtn && nextBtn) {
                        prevBtn.disabled = this.isBeginning;
                        nextBtn.disabled = this.isEnd;
                    }
                }
            }
        });

        return () => swiper.destroy();
    }

    let cleanup: (() => void) | undefined;

    function initialize() {
        if (cleanup) cleanup();
        cleanup = initProjectNavigation();
    }

    // Initial load
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initialize);
    } else {
        initialize();
    }

    // Handle Astro page transitions
    document.addEventListener('astro:page-load', initialize);
    document.addEventListener('astro:before-swap', () => {
        if (cleanup) cleanup();
    });

    // Spotify Now Playing
    function fetchSpotifyTrack() {
        const user = 'sjalssokande';
        const url = `https://lastfm-last-played.biancarosa.com.br/${user}/latest-song`;
        
        fetch(url)
            .then(response => response.json())
            .then(data => {
                const trackElement = document.getElementById('now-playing-inline');
                if (trackElement && data.track) {
                    const artist = data.track.artist['#text'] || 'Unknown Artist';
                    const song = data.track.name || 'Unknown Track';
                    
                    trackElement.innerHTML = `
                        <span class="track-icon">♫</span>
                        <span class="track-artist">${artist}</span>
                        <span> — </span>
                        <span class="track-name">${song}</span>
                    `;
                }
            })
            .catch(err => {
                console.log('Spotify track fetch error:', err);
                const trackElement = document.getElementById('now-playing-inline');
                if (trackElement) {
                    trackElement.innerHTML = '<span class="track-loading">Not playing</span>';
                }
            });
    }

    // Fetch on page load
    fetchSpotifyTrack();

    // Refresh every 30 seconds
    setInterval(fetchSpotifyTrack, 30000);
</script>